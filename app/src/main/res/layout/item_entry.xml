<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:padding="12dp" android:orientation="vertical"
    android:layout_width="match_parent" android:layout_height="wrap_content">
    <TextView android:id="@+id/itemTitle" android:textStyle="bold" android:textSize="16sp" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/itemBody" android:maxLines="2" android:ellipsize="end" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/itemDate" android:textSize="12sp" android:layout_width="match_parent" android:layout_height="wrap_content"/>
</LinearLayout>